# Constant Contact integration — copy to Vercel project env vars.
# (Do NOT commit real values. .env* is gitignored.)

# From your Constant Contact developer app (V3 API key + secret):
CC_CLIENT_ID=
CC_CLIENT_SECRET=

# Constant Contact list IDs (Contacts > Lists, in the CC dashboard / API).
# Both forms add contacts; inquiry leads and newsletter signups can go to
# the same list or two different lists.
CC_LIST_INQUIRY=
CC_LIST_NEWSLETTER=

# Auto-provided by Vercel KV when you create a KV store — no need to set by hand:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
